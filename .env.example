# ───────────────────────────────────────────────────────
# アプリ認証設定 (外部公開する場合は必ず設定してください)
# ───────────────────────────────────────────────────────

# アクセスパスワード (未設定の場合はパスワード不要)
APP_PASSWORD=your-password-here

# Cookie署名用シークレットキー (ランダムな長い文字列を設定)
APP_SECRET_KEY=change-this-to-a-long-random-string

# ───────────────────────────────────────────────────────
# OpenAI API Key
# https://platform.openai.com/api-keys から取得
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI モデル設定 (デフォルト: gpt-4o)
OPENAI_MODEL=gpt-4o

# YouTube API OAuth2 クライアントシークレットファイルのパス
# Google Cloud Console から取得: https://console.cloud.google.com/
YOUTUBE_CLIENT_SECRETS_FILE=client_secrets.json

# アップロード先 YouTube チャンネルID (省略可: デフォルトは認証済みアカウントのチャンネル)
# YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxxxxx

# Whisper モデルサイズ: tiny, base, small, medium, large-v2, large-v3
# large-v3 が最高精度だがVRAMが多く必要。CPUでも動作するが遅い。
WHISPER_MODEL=large-v3

# 処理デバイス: cuda (GPU) or cpu
WHISPER_DEVICE=cpu

# 出力ディレクトリ
OUTPUT_DIR=output

# 動画ダウンロード時の最大解像度 (例: 1080, 720, 480)
MAX_VIDEO_HEIGHT=1080

# ───────────────────────────────────────────────────────
# 概要欄フッター（任意）
# 全てのアップロード動画の概要欄末尾に自動追加されるデフォルトテキスト。
# 改行は \n で表現してください。UIからチャンネル別に追加テキストを指定することも可能。
# DESCRIPTION_FOOTER=チャンネル登録・高評価よろしくお願いします！\n\n▼ 関連リンク\nhttps://example.com

# ───────────────────────────────────────────────────────
# yt-dlp 用 Cookie（任意・推奨: VPS / クラウドで「ボット確認」を求められる場合）
# PC のブラウザで YouTube にログインした状態の Netscape 形式 cookies.txt をサーバーに置き、絶対パスで指定。
# 例: Get cookies.txt LOCALLY 拡張、または yt-dlp --cookies-from-browser で抽出したファイル
# YOUTUBE_COOKIES_FILE=/opt/kirinuki/secrets/youtube_cookies.txt
